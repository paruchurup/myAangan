# ─────────────────────────────────────────────────────────────
# MyAangan - Environment Variables for Docker Compose
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────

# Database
DB_ROOT_PASSWORD=ChangeMe_RootPass123!
DB_USER=myaangan
DB_PASSWORD=ChangeMe_AppPass123!

# JWT — must be at least 32 characters
JWT_SECRET=MyAanganSuperSecretKey2024PleaseChangeThisNow!

# CORS — comma-separated list of allowed frontend origins
# For EC2: use your public IP or domain
CORS_ORIGINS=http://localhost,http://YOUR_EC2_IP
